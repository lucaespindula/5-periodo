8- [Serializable]
public class LimiteDiarioAcumuladoException : Exception
{
    public LimiteDiarioAcumuladoException(string message)
        : base(message) { }
}

private decimal totalSacadoHoje = 0;
private const decimal LIMITE_DIARIO = 1000;

public decimal Sacar(decimal valor)
{
    if (valor <= 0)
        throw new ArgumentException("Valor do saque deve ser positivo");

    if (valor > 500)
        throw new LimiteDiarioException(valor);

    if (totalSacadoHoje + valor > LIMITE_DIARIO)
        throw new LimiteDiarioAcumuladoException("Limite diário de saque excedido");

    try
    {
        if (Saldo < valor)
            throw new Exception("Saldo insuficiente (erro interno)");

        Saldo -= valor;
        totalSacadoHoje += valor;

        return Saldo;
    }
    catch (Exception ex)
    {
        throw new SaldoInsuficienteException(valor, Saldo, ex);
    }
}
