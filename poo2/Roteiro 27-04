2- using System;

[Serializable]
public class LimiteDiarioException : Exception
{
    public decimal Valor { get; }

    public LimiteDiarioException() { }

    public LimiteDiarioException(string message)
        : base(message) { }

    public LimiteDiarioException(string message, Exception inner)
        : base(message, inner) { }

    public LimiteDiarioException(decimal valor)
        : base($"Saque de {valor} excede o limite por operação de 500")
    {
        Valor = valor;
    }
}

public decimal Sacar(decimal valor)
{
    if (valor <= 0)
        throw new ArgumentException("Valor do saque deve ser positivo");

    if (valor > 500)
        throw new LimiteDiarioException(valor);

    try
    {
        if (Saldo < valor)
            throw new Exception("Saldo insuficiente (erro interno)");

        Saldo -= valor;
        return Saldo;
    }
    catch (Exception ex)
    {
        throw new SaldoInsuficienteException(valor, Saldo, ex);
    }
}

3- public void Transferir(Conta destino, decimal valor)
{
    if (destino == null)
        throw new ArgumentException("Conta de destino inválida");

    if (valor <= 0)
        throw new ArgumentException("Valor deve ser positivo");

    // garante consistência: só deposita se sacar funcionar
    this.Sacar(valor);
    destino.Depositar(valor);
}

